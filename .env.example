# Database
DATABASE_URL="postgresql://user:password@localhost:5432/reviewbot"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-min-32-chars-here"

# Google OAuth + GMB API
# اتبع الخطوات في README.md لإنشاء هذه المفاتيح
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Claude AI (Anthropic)
ANTHROPIC_API_KEY="your-anthropic-api-key"

# App Config
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ReviewBot AI"
CRON_SECRET="random-secret-for-cron-jobs"
