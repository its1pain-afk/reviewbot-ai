// prisma/schema.prisma
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  plan          String    @default("FREE")
  googleTokens  String?   // JSON string: { access_token, refresh_token, expiry_date }
  lateProfileId String?   // Late.dev profile ID for unified inbox
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  locations      Location[]
  botConfigs     BotConfig[]
  accounts       Account[]
  sessions       Session[]
  subscription   Subscription?
  socialAccounts SocialAccount[]
  knowledgeBase  KnowledgeBase[]
  inboxBotConfig InboxBotConfig?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? // @db.Text
  session_state     String?
  refresh_token_expires_in Int?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Location {
  id              String    @id @default(cuid())
  userId          String
  gmbAccountId    String
  gmbLocationId   String
  name            String
  address         String?
  phone           String?
  website         String?
  category        String?
  isActive        Boolean   @default(true)
  botEnabled      Boolean   @default(true)
  totalReviews    Int       @default(0)
  avgRating       Float     @default(0)
  repliedCount    Int       @default(0)
  lastSyncAt      DateTime?
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews         Review[]
  botConfig       BotConfig?

  @@unique([userId, gmbLocationId])
}

model Review {
  id              String    @id @default(cuid())
  locationId      String
  gmbReviewId     String    @unique
  reviewerName    String
  reviewerPhoto   String?
  rating          Int
  comment         String?
  publishedAt     DateTime
  replied         Boolean   @default(false)
  replyText       String?
  repliedAt       DateTime?
  replyStatus     String    @default("PENDING")
  aiGenerated     Boolean   @default(false)
  createdAt       DateTime  @default(now())

  location        Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

model BotConfig {
  id                String    @id @default(cuid())
  userId            String
  locationId        String    @unique
  businessName      String
  businessType      String
  dialect           String    @default("saudi")
  tone              String    @default("warm")
  replySpeed        String    @default("2h")
  personality       String    @default("friendly")
  includeEmoji      Boolean   @default(true)
  signatureName     String?
  fiveStar          String?
  fourStar          String?
  threeStar         String?
  twoStar           String?
  oneStar           String?
  customContext     String?
  forbiddenWords    String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User      @relation(fields: [userId], references: [id])
  location          Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

model Subscription {
  id              String    @id @default(cuid())
  userId          String    @unique
  plan            String
  status          String    @default("ACTIVE")
  locationsLimit  Int       @default(1)
  currentPeriodEnd DateTime?
  createdAt       DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id])
}

// ─── Late.dev Unified Inbox Models ────────────────────────────────

model SocialAccount {
  id            String         @id @default(cuid())
  userId        String
  platform      String         // "whatsapp" | "messenger" | "instagram" | "x"
  lateAccountId String         @unique
  accountName   String
  accountAvatar String?
  isActive      Boolean        @default(true)
  connectedAt   DateTime       @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([userId, platform, lateAccountId])
}

model Conversation {
  id                 String        @id @default(cuid())
  socialAccountId    String
  lateConversationId String        @unique
  platform           String        // denormalized for filtering
  contactName        String
  contactAvatar      String?
  contactId          String?
  lastMessageText    String?
  lastMessageAt      DateTime?
  unreadCount        Int           @default(0)
  status             String        @default("active") // "active" | "archived"
  autoReplyEnabled   Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  socialAccount      SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  messages           Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  lateMessageId  String       @unique
  direction      String       // "inbound" | "outbound"
  content        String
  contentType    String       @default("text") // "text" | "image" | "video" | "audio" | "file"
  mediaUrl       String?
  replyStatus    String       @default("NONE") // NONE | PENDING | PROCESSING | SENT | FAILED
  aiGenerated    Boolean      @default(false)
  sentAt         DateTime
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model KnowledgeBase {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  category  String   @default("general") // "faq" | "product" | "policy" | "general"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InboxBotConfig {
  id             String   @id @default(cuid())
  userId         String   @unique
  isActive       Boolean  @default(true)
  replyMode      String   @default("manual") // "auto" | "manual"
  dialect        String   @default("saudi")
  personality    String   @default("friendly")
  includeEmoji   Boolean  @default(true)
  signatureName  String?
  businessName   String?
  businessType   String?
  forbiddenWords String?
  maxReplyLength Int      @default(150)
  autoReplyDelay Int      @default(5)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id])
}
